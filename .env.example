# Database (required)
DATABASE_URL="postgresql://user:password@host:5432/raafat?schema=public"

# Better Auth (required)
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET="generate-a-long-random-secret"
# Must match your public URL exactly (https in production)
BETTER_AUTH_URL="https://your-domain.com"

# Public app URL (required — used for auth callbacks and metadata)
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# OAuth (optional — set NEXT_PUBLIC_* to "true" to show sign-in buttons)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_ENABLED="false"
NEXT_PUBLIC_GITHUB_ENABLED="false"

# Docker / Coolify (optional)
# SKIP_MIGRATE=true          # skip prisma migrate deploy on container start
# RUN_DB_SEED=true           # import meshia_dictionary.json on first deploy only
# PORT=3000                  # default 3000
